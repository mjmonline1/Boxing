{
  "name": "boxing-tournament-manager",
  "version": "1.3.12",
  "description": "TSC Boxing Tournament Management Tool",
  "main": "Server.js",
  "scripts": {
    "start": "node Server.js",
    "test": "node --test --test-concurrency=9",
    "coverage": "c8 node --test --test-concurrency=9"
  },
  "c8": {
    "all": true,
    "include": ["*.js"],
    "exclude": [
      "tests/**",
      "importBoxersToMongo.js",
      "tsc-tournament-2026.js",
      "Server.js",
      "create-petri-net.js",
      "data-client.js",
      "theme.js"
    ],
    "reporter": ["text", "lcov"]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mongodb": "^6.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "mongodb-memory-server": "^11.2.0"
  }
}
